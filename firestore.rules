rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // salesDb (default DB) 규칙 파일
    // - user_status 컬렉션을 salesDb에 미러링하여 isApprovedUser() 구현
    // - isAdmin()은 하드코딩 이메일로 동작
    // - 해고/정지 직원은 Admin에서 user_status를 업데이트하면 즉시 차단
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "saemoyang_official@naver.com" ||
        request.auth.token.email == "wnsdl9331@gmail.com"
      );
    }

    // user_status는 salesDb에 미러링된 컬렉션 — 크로스 DB 조회 불필요
    function isApprovedUser() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/user_status/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/user_status/$(request.auth.uid)).data.isApproved == true &&
        get(/databases/$(database)/documents/user_status/$(request.auth.uid)).data.isActive == true;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // ── user_status 미러 컬렉션 (salesDb-native 사용자 상태) ────────
    // App.tsx 로그인 시, AdminPanel 승인/정지/삭제 시 자동 동기화
    match /user_status/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create, update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── named DB 컬렉션 규칙 (같은 Firebase 프로젝트 기본 DB에도 적용) ─
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) &&
                    hasOnlyAllowedFields(['uid', 'email', 'name', 'role', 'isApproved', 'isActive', 'theme', 'createdAt', 'alertThresholdType', 'alertThresholdValue']) &&
                    request.resource.data.uid is string && request.resource.data.uid.size() > 0 &&
                    request.resource.data.email is string && request.resource.data.email.size() > 0 &&
                    request.resource.data.name is string && request.resource.data.name.size() > 0 &&
                    request.resource.data.role in ['admin', 'user'] &&
                    (request.resource.data.isApproved is bool || !('isApproved' in request.resource.data)) &&
                    (request.resource.data.isActive is bool || !('isActive' in request.resource.data)) &&
                    (
                      (request.resource.data.role == 'user' && request.resource.data.isApproved == false && request.resource.data.isActive == true) ||
                      isAdmin()
                    ) &&
                    request.resource.data.uid == userId;
      allow update: if (isOwner(userId) && areImmutableFieldsUnchanged(['uid', 'email', 'role', 'isApproved', 'isActive', 'createdAt'])) ||
                    (isAdmin() && areImmutableFieldsUnchanged(['uid', 'email', 'createdAt']));
      allow delete: if isAdmin();
    }

    match /menu_categories/{categoryId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    match /menus/{menuId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin() || isAuthenticated();
    }

    match /ingredients/{ingredientId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    match /ingredient_changes/{changeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // ── salesDb 핵심 운영 컬렉션 (isApprovedUser 적용) ─────────────

    // 회의록: 승인된 재직 직원만 읽기/쓰기, 삭제는 관리자
    match /meetings/{meetingId} {
      allow read, create, update: if isApprovedUser() || isAdmin();
      allow delete: if isAdmin();
    }

    // 업무일지: 승인된 재직 직원만
    match /daily_reports/{docId} {
      allow read, write: if isApprovedUser() || isAdmin();
      match /comments/{commentId} {
        allow read, write: if isApprovedUser() || isAdmin();
      }
    }

    // 업무(tasks): 승인된 재직 직원만
    match /tasks/{docId} {
      allow read, write: if isApprovedUser() || isAdmin();
    }

    // 업무지도 프로젝트: 승인된 재직 직원만
    match /task_projects/{docId} {
      allow read, write: if isApprovedUser() || isAdmin();
    }

    // ── salesDb 일반 운영 컬렉션 (isAuthenticated 적용) ────────────

    // 회의 템플릿: 읽기 = 인증, 쓰기 = 관리자
    match /meeting_templates/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // 직원: 읽기 = 인증, 쓰기 = 관리자
    match /employees/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // 공지: 읽기 = 인증, 생성/삭제 = 관리자, 읽음 처리(readBy만) = 승인된 직원
    match /notices/{docId} {
      allow read: if isAuthenticated();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() ||
        (isApprovedUser() &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']));
    }

    // 일정
    match /calendar_events/{docId}     { allow read, write: if isAuthenticated(); }
    match /calendar_routines/{docId}   { allow read, write: if isAuthenticated(); }
    match /routine_completions/{docId} { allow read, write: if isAuthenticated(); }

    // 휴가
    match /leave_requests/{docId}      { allow read, write: if isAuthenticated(); }

    // 프로젝트
    match /projects/{docId} {
      allow read, write: if isAuthenticated();
      match /{sub}/{subId}             { allow read, write: if isAuthenticated(); }
    }
    match /project_folders/{docId}     { allow read, write: if isAuthenticated(); }
    match /project_items/{docId}       { allow read, write: if isAuthenticated(); }
    match /project_mindmaps/{docId}    { allow read, write: if isAuthenticated(); }
    match /reports/{docId}             { allow read, write: if isAuthenticated(); }

    // 보고서/SOP: 읽기 = 인증, 쓰기 = 관리자
    match /sop_documents/{docId}       { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /sop_project_templates/{docId} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /process_settings/{docId}    { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /system_settings/{docId}     { allow read: if isAuthenticated(); allow write: if isAdmin(); }

    // 매장 폼 관리 (폼 생성/수정은 인증 사용자 전체, 이력은 updatedBy 필드로 추적)
    match /store_forms/{docId}             { allow read, write: if isAuthenticated(); }
    match /store_form_entries/{docId}      { allow read, write: if isAuthenticated(); }

    // 매장/프랜차이즈
    match /stores/{docId}                  { allow read, write: if isAuthenticated(); }
    // 매장 설정 (숨김 목록 등) — 읽기: 인증, 쓰기: 관리자
    match /store_settings/{docId}          { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /store_mentions/{docId}          { allow read, write: if isAuthenticated(); }
    match /franchise_schedules/{docId}     { allow read, write: if isAuthenticated(); }
    match /department_tasks/{docId}        { allow read, write: if isAuthenticated(); }
    match /departments/{docId}             { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /team_settings/{docId}           { allow read, write: if isAuthenticated(); }
    match /task_templates/{docId}          { allow read, write: if isAuthenticated(); }

    // OKR/목표
    match /weekly_reports/{docId}      { allow read, write: if isAuthenticated(); }
    match /okr_quarters/{docId}        { allow read, write: if isAuthenticated(); }
    match /brand_milestones/{docId}    { allow read, write: if isAuthenticated(); }
    match /company_info/{docId}        { allow read: if isAuthenticated(); allow write: if isAdmin(); }

    // 제조실
    match /factory_items/{docId}       { allow read, write: if isAuthenticated(); }
    match /factory_daily/{docId}       { allow read, write: if isAuthenticated(); }
    match /factory_settings/{docId}    { allow read, write: if isAuthenticated(); }

    // 마케팅
    match /menu_sales/{docId}          { allow read, write: if isAuthenticated(); }

    // 개인 메모 — 본인만 읽기/쓰기
    match /user_memos/{memoId} {
      allow read, update, delete: if isAuthenticated() && request.auth.uid == resource.data.uid;
      allow create:               if isAuthenticated() && request.resource.data.uid == request.auth.uid;
    }
  }
}
