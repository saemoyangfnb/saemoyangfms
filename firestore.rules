rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - uid: string (required, immutable)
    //   - email: string (required, immutable)
    //   - name: string (required)
    //   - role: string (required, 'admin' or 'user')
    //   - isApproved: boolean (required)
    //   - isActive: boolean (required)
    //   - createdAt: string (required, immutable)
    //
    // Collection: menus
    // Document ID: menuId
    // Fields:
    //   - id: string (required, immutable)
    //   - name: string (required)
    //   - prices: map (required)
    //   - recipe: list (required)
    //   - isArchived: boolean (required)
    //   - createdAt: string (required, immutable)
    //
    // Collection: ingredients
    // Document ID: ingredientId
    // Fields:
    //   - id: string (required, immutable)
    //   - name: string (required)
    //   - boxCost: number (required)
    //   - boxQuantity: number (required)
    //   - unitCost: number (required)
    //   - unit: string (required, 'kg', 'g', 'ea', '미')
    //   - isArchived: boolean (required)
    //   - createdAt: string (required, immutable)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "saemoyang_official@naver.com" ||
        request.auth.token.email == "wnsdl9331@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isApprovedUser() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isApproved == true &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isActive == true;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // Domain Validators
    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'email', 'name', 'role', 'isApproved', 'isActive', 'theme', 'createdAt', 'alertThresholdType', 'alertThresholdValue']) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 200 &&
             data.email is string && data.email.size() > 0 && data.email.size() < 200 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.role in ['admin', 'user'] &&
             (data.isApproved is bool || !('isApproved' in data)) &&
             (data.isActive is bool || !('isActive' in data)) &&
             (data.theme in ['light', 'dark'] || !('theme' in data)) &&
             (data.createdAt is string || !('createdAt' in data)) &&
             (data.alertThresholdType in ['percentage', 'absolute'] || !('alertThresholdType' in data)) &&
             (data.alertThresholdValue is number || !('alertThresholdValue' in data));
    }

    function isValidMenuCategory(data) {
      return hasOnlyAllowedFields(['id', 'name', 'order', 'isVisible']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 200 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.order is number &&
             data.isVisible is bool;
    }

    function isValidMenu(data) {
      return hasOnlyAllowedFields(['id', 'name', 'categoryId', 'order', 'isVisible', 'prices', 'recipe', 'notes', 'isArchived', 'createdAt', 'hasAlert', 'lastAcknowledgedCost']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 200 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             (data.categoryId is string || !('categoryId' in data)) &&
             (data.order is number || !('order' in data)) &&
             (data.isVisible is bool || !('isVisible' in data)) &&
             data.prices is map &&
             data.recipe is list && data.recipe.size() <= 100 &&
             (data.notes is string && data.notes.size() <= 5000 || !('notes' in data)) &&
             (data.isArchived is bool || !('isArchived' in data)) &&
             (data.createdAt is string || !('createdAt' in data)) &&
             (data.hasAlert is bool || !('hasAlert' in data)) &&
             (data.lastAcknowledgedCost is number || !('lastAcknowledgedCost' in data));
    }

    function isValidIngredient(data) {
      return hasOnlyAllowedFields(['id', 'name', 'spec', 'boxCost', 'boxQuantity', 'unitCost', 'salesPrice', 'unitSalesPrice', 'unit', 'isArchived', 'isSelectedForMenu', 'createdAt']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 300 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 300 &&
             (data.spec is string || !('spec' in data)) &&
             data.boxCost is number && data.boxCost >= 0 &&
             data.boxQuantity is number && data.boxQuantity > 0 &&
             data.unitCost is number && data.unitCost >= 0 &&
             (data.salesPrice is number && data.salesPrice >= 0 || !('salesPrice' in data)) &&
             (data.unitSalesPrice is number && data.unitSalesPrice >= 0 || !('unitSalesPrice' in data)) &&
             (data.unit is string || !('unit' in data)) &&
             (data.isArchived is bool || !('isArchived' in data)) &&
             (data.isSelectedForMenu is bool || !('isSelectedForMenu' in data)) &&
             (data.createdAt is string || !('createdAt' in data));
    }

    function isValidIngredientChange(data) {
      return hasOnlyAllowedFields(['id', 'ingredientId', 'name', 'spec', 'type', 'prevPurchasePrice', 'currPurchasePrice', 'prevSalesPrice', 'currSalesPrice', 'timestamp']) &&
             data.id is string && data.id.size() < 400 &&
             data.ingredientId is string && data.ingredientId.size() < 300 &&
             data.name is string && data.name.size() > 0 &&
             (data.spec is string || !('spec' in data)) &&
             data.type in ['new', 'deleted', 'price_change', 'bulk_update'] &&
             (data.prevPurchasePrice is number || !('prevPurchasePrice' in data)) &&
             (data.currPurchasePrice is number || !('currPurchasePrice' in data)) &&
             (data.prevSalesPrice is number || !('prevSalesPrice' in data)) &&
             (data.currSalesPrice is number || !('currSalesPrice' in data)) &&
             data.timestamp is string;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      // Users can create their own profile, but must be 'user', not approved, and active.
      allow create: if isOwner(userId) && isValidUser(request.resource.data) &&
                    (
                      (request.resource.data.role == 'user' && request.resource.data.isApproved == false && request.resource.data.isActive == true) ||
                      isAdmin()
                    ) &&
                    request.resource.data.uid == userId;
                    
      // Users can update their own name, but not role, approval, active status, etc.
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && areImmutableFieldsUnchanged(['uid', 'email', 'role', 'isApproved', 'isActive', 'createdAt'])) ||
                    (isAdmin() && isValidUser(request.resource.data) && areImmutableFieldsUnchanged(['uid', 'email', 'createdAt']));
                    
      allow delete: if isAdmin();
    }

    match /menu_categories/{categoryId} {
      allow read: if isAdmin() || isApprovedUser();
      allow create: if isAdmin() && isValidMenuCategory(request.resource.data);
      allow update: if isAdmin() && isValidMenuCategory(request.resource.data) && areImmutableFieldsUnchanged(['id']);
      allow delete: if isAdmin();
    }

    match /menus/{menuId} {
      allow read: if isAdmin() || isApprovedUser();
      allow create: if (isAdmin() || isApprovedUser()) && isValidMenu(request.resource.data);
      allow update: if (isAdmin() || isApprovedUser()) && isValidMenu(request.resource.data) && areImmutableFieldsUnchanged(['id', 'createdAt']);
      allow delete: if isAdmin() || isApprovedUser();
    }

    match /ingredients/{ingredientId} {
      allow read: if isAdmin() || isApprovedUser();
      allow create: if (isAdmin() || isApprovedUser()) && isValidIngredient(request.resource.data);
      allow update: if (isAdmin() || isApprovedUser()) && 
                    isValidIngredient(request.resource.data) && 
                    (isAdmin() || (areImmutableFieldsUnchanged(['id', 'createdAt']) || !('createdAt' in resource.data)));
      allow delete: if isAdmin() || isApprovedUser();
    }

    match /ingredient_changes/{changeId} {
      allow read: if isAdmin() || isApprovedUser();
      allow create: if (isAdmin() || isApprovedUser()) && isValidIngredientChange(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
