{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile containing role and approval status",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "isApproved": { "type": "boolean" },
        "isActive": { "type": "boolean" },
        "theme": { "type": "string", "enum": ["light", "dark"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "name", "role", "isApproved", "isActive", "createdAt"]
    },
    "MenuCategory": {
      "title": "MenuCategory",
      "description": "Category for grouping menus",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "order": { "type": "number" },
        "isVisible": { "type": "boolean" }
      },
      "required": ["id", "name", "order", "isVisible"]
    },
    "Menu": {
      "title": "Menu",
      "description": "Menu item with regional prices and recipe",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "categoryId": { "type": "string" },
        "order": { "type": "number" },
        "isVisible": { "type": "boolean" },
        "prices": {
          "type": "object",
          "properties": {
            "지방권": { "type": "number" },
            "광역권": { "type": "number" },
            "수도권": { "type": "number" }
          }
        },
        "recipe": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "ingredientId": { "type": "string" },
              "quantity": { "type": "number" }
            }
          }
        },
        "notes": { "type": "string" },
        "hasAlert": { "type": "boolean" },
        "lastAcknowledgedCost": { "type": "number" },
        "isArchived": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "prices", "recipe", "isArchived", "createdAt"]
    },
    "Ingredient": {
      "title": "Ingredient",
      "description": "Ingredient with cost and unit",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "spec": { "type": "string" },
        "boxCost": { "type": "number" },
        "boxQuantity": { "type": "number" },
        "unitCost": { "type": "number" },
        "salesPrice": { "type": "number" },
        "unitSalesPrice": { "type": "number" },
        "unit": { "type": "string", "enum": ["kg", "g", "ea", "미"] },
        "isArchived": { "type": "boolean" },
        "isSelectedForMenu": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "boxCost", "boxQuantity", "unitCost", "unit", "isArchived", "createdAt"]
    },
    "IngredientChange": {
      "title": "IngredientChange",
      "description": "Record of ingredient price or status changes",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ingredientId": { "type": "string" },
        "name": { "type": "string" },
        "spec": { "type": "string" },
        "type": { "type": "string", "enum": ["new", "deleted", "price_change"] },
        "prevPurchasePrice": { "type": "number" },
        "currPurchasePrice": { "type": "number" },
        "prevSalesPrice": { "type": "number" },
        "currSalesPrice": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "ingredientId", "name", "type", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/menu_categories/{categoryId}": {
      "schema": { "$ref": "#/entities/MenuCategory" },
      "description": "Menu categories"
    },
    "/menus/{menuId}": {
      "schema": { "$ref": "#/entities/Menu" },
      "description": "Menu items"
    },
    "/ingredients/{ingredientId}": {
      "schema": { "$ref": "#/entities/Ingredient" },
      "description": "Ingredients"
    },
    "/ingredient_changes/{changeId}": {
      "schema": { "$ref": "#/entities/IngredientChange" },
      "description": "Ingredient change history"
    }
  }
}
